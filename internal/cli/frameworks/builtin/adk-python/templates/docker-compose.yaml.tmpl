      - OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
      - MODEL_PROVIDER={{.ModelProvider}}
      - MODEL_NAME={{.ModelName}}
      # MCP wiring: pass these through from the host's .env if present.
